            "id": 12,
            "type": "table",
            "title": "📋 Chi tiết mã sắp đáo hạn (14 ngày tới)",
            "description": "Danh sách các mã phái sinh/chứng quyền đang active và sẽ đáo hạn trong 14 ngày tới, sorted theo ngày đáo hạn gần nhất.",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT\n  sd.symbol                        AS \"Symbol\",\n  CASE sd.market_id\n    WHEN 'STO' THEN 'HOSE'\n    WHEN 'DVX' THEN 'Phai sinh'\n    WHEN 'HCX' THEN 'CW'\n    ELSE sd.market_id\n  END                              AS \"San\",\n  sd.security_group_id             AS \"Loai\",\n  sd.final_trade_date              AS \"Ngay dao han\",\n  (sd.final_trade_date - CURRENT_DATE) AS \"Con lai (ngay)\"\nFROM security_definition sd\nJOIN instrument_master im\n  ON sd.symbol = im.symbol AND sd.market_id = im.market_id\nWHERE sd.trading_date = CURRENT_DATE\n  AND sd.final_trade_date IS NOT NULL\n  AND sd.final_trade_date > CURRENT_DATE\n  AND sd.final_trade_date <= CURRENT_DATE + INTERVAL '14 days'\n  AND im.is_active = true\nORDER BY sd.final_trade_date, sd.symbol",
                    "format": "table",
                    "refId": "A"
                }
            ],
