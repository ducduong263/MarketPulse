        {
            "id": 6,
            "type": "timeseries",
            "title": "📊 Kafka Consumer Lag (từ Prometheus)",
            "description": "Consumer lag của các group timescaledb-*. Cao > 1000 = consumer bị quá tải.",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum by(consumergroup, topic) (kafka_consumergroup_lag{consumergroup=~\"timescaledb-.*\"})",
                    "legendFormat": "{{consumergroup}} - {{topic}}",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
