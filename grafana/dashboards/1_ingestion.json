        {
            "id": 9,
            "type": "stat",
            "title": "Mã Subscribe theo Sàn (dynamic filter)",
            "description": "Số mã chứng khoán đang được subscribe, phân theo sàn. Bộ lọc (board_id, status, admin, sanction, market, indexes, groups) được tải động từ bảng pipeline_config trong DB.",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT\n  CASE sd.market_id\n    WHEN 'STO' THEN 'HOSE'\n    WHEN 'STX' THEN 'HNX'\n    WHEN 'UPX' THEN 'UPCOM'\n    WHEN 'DVX' THEN 'Phai sinh'\n    WHEN 'HCX' THEN 'CW'\n    ELSE sd.market_id\n  END AS metric,\n  COUNT(DISTINCT sd.symbol) AS value\nFROM security_definition sd\nJOIN instrument_master im\n  ON sd.symbol = im.symbol AND sd.market_id = im.market_id\nWHERE sd.trading_date = CURRENT_DATE\n  AND sd.board_id = (SELECT value FROM pipeline_config WHERE key = 'symbol_filter_board_id')\n  AND (\n    COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_status'), '') = ''\n    OR sd.security_status = ANY(string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_status'), ','))\n  )\n  AND (\n    COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_admin'), '') = ''\n    OR sd.admin_status = ANY(string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_admin'), ','))\n  )\n  AND (\n    COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_sanction'), '') = ''\n    OR sd.trading_sanction_status = ANY(string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_sanction'), ','))\n  )\n  AND im.is_active = true\n  AND (\n    COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_market'), '') = ''\n    OR sd.market_id = ANY(string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_market'), ','))\n  )\n  AND (\n    (\n      COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_indexes'), '') = ''\n      AND COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_groups'), '') = ''\n    )\n    OR (\n      COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_indexes'), '') <> ''\n      AND string_to_array(im.index_name, ',') && string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_indexes'), ',')\n    )\n    OR (\n      COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_groups'), '') <> ''\n      AND im.security_group_id = ANY(string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_groups'), ','))\n    )\n  )\nGROUP BY sd.market_id\nORDER BY metric",
                    "format": "table",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "blue"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "blue",
                                "value": null
                            }
                        ]
                    },
                    "unit": "short",
                    "mappings": []
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "/^value$/",
                    "values": true
                },
                "orientation": "horizontal",
                "textMode": "value_and_name",
                "colorMode": "background",
                "text": {
                    "titleSize": 14,
                    "valueSize": 28
                },
                "graphMode": "none"
            },
            "gridPos": {
                "h": 5,
                "w": 14,
                "x": 0,
                "y": 35
            }
