        {
            "id": 6,
            "type": "timeseries",
            "title": "📊 Kafka Consumer Lag (từ Prometheus)",
            "description": "Consumer lag của các group timescaledb-*. Nếu lag > 1000 = Consumer bị quá tải.",
            "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "prometheus",
                        "uid": "prometheus"
                    },
                    "expr": "sum by(consumergroup, topic) (kafka_consumergroup_lag{consumergroup=~\"timescaledb-.*\"})",
                    "legendFormat": "{{consumergroup}} - {{topic}}",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 10
                    },
                    "unit": "short",
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 100
                            },
                            {
                                "color": "red",
                                "value": 1000
                            }
                        ]
                    }
                }
            },
            "options": {
                "tooltip": {
                    "mode": "multi"
                },
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom",
                    "showLegend": true
                }
            },
            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 18
            }
        },
        {
            "id": 7,
            "type": "state-timeline",
            "title": "🔌 Trạng thái kết nối của Service (Online / Offline)",
            "description": "Dải xanh = Online, Đỏ = Offline. Hover vào vùng đỏ để xem thời gian mất kết nối. Mỗi lần restart container hoặc mất mạng đều được ghi nhận.",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT\n  $__timeFrom() AS time,\n  s.service_name AS metric,\n  COALESCE(\n    (\n      SELECT metric_value\n      FROM pipeline_stats\n      WHERE service_name = s.service_name\n        AND metric_name = 'connection_status'\n        AND ts <= $__timeFrom()\n      ORDER BY ts DESC\n      LIMIT 1\n    ), 0.0\n  ) AS value\nFROM (\n  VALUES\n    ('p-trade'), ('p-quote'), ('p-index'), ('p-expected-price'), ('p-foreign-investor'),\n    ('c-trade'), ('c-quote'), ('c-index'), ('c-expected-price'), ('c-foreign-investor')\n) AS s(service_name)\n\nUNION ALL\n\nSELECT\n  ts AS time,\n  service_name AS metric,\n  metric_value AS value\nFROM pipeline_stats\nWHERE metric_name = 'connection_status'\n  AND $__timeFilter(ts)\n\nUNION ALL\n\nSELECT\n  $__timeTo() AS time,\n  s.service_name AS metric,\n  COALESCE(\n    (\n      SELECT metric_value\n      FROM pipeline_stats\n      WHERE service_name = s.service_name\n        AND metric_name = 'connection_status'\n        AND ts <= $__timeTo()\n      ORDER BY ts DESC\n      LIMIT 1\n    ), 0.0\n  ) AS value\nFROM (\n  VALUES\n    ('p-trade'), ('p-quote'), ('p-index'), ('p-expected-price'), ('p-foreign-investor'),\n    ('c-trade'), ('c-quote'), ('c-index'), ('c-expected-price'), ('c-foreign-investor')\n) AS s(service_name)\n\nORDER BY time",
                    "format": "time_series",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "lineWidth": 1,
                        "fillOpacity": 70,
                        "connectNullValues": "always",
                        "spanNulls": true
                    },
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "0": {
                                    "text": "Offline",
                                    "color": "red",
                                    "index": 0
                                }
                            }
                        },
                        {
                            "type": "value",
                            "options": {
                                "1": {
                                    "text": "Online",
                                    "color": "green",
                                    "index": 1
                                }
                            }
                        }
                    ],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "green",
                                "value": 1
                            }
                        ]
                    },
                    "color": {
                        "mode": "thresholds"
                    }
                }
            },
            "options": {
                "mergeValues": true,
                "showValue": "never",
                "alignValue": "center",
                "rowHeight": 0.85,
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom",
                    "showLegend": true
                },
                "tooltip": {
                    "mode": "single"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 26
            }
        },
        {
            "id": 8,
            "type": "row",
            "title": "📋 Danh mục mã đang Subscribe (Instrument Master)",
            "collapsed": false,
            "gridPos": {
                "h": 1,
                "w": 24,
                "x": 0,
                "y": 34
            },
            "description": "Danh sách tổng hợp các mã chứng khoán."
        },
        {
            "id": 9,
            "type": "stat",
            "title": "📊 Số lượng mã Subscribe theo Sàn (Dynamic Filter)",
            "description": "Số lượng mã chứng khoán đang được subscribe, phân loại theo sàn. Bộ lọc (board_id, status, admin, sanction, market, indexes, groups) được tải động từ bảng pipeline_config.",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT\n  CASE sd.market_id\n    WHEN 'STO' THEN 'Cổ phiếu sàn HOSE'\n    WHEN 'STX' THEN 'Cổ phiếu sàn HNX'\n    WHEN 'UPX' THEN 'Cổ phiếu sàn Upcom'\n    WHEN 'DVX' THEN 'Phái sinh sàn HNX'\n    WHEN 'HCX' THEN 'Trái phiếu doanh nghiệp sàn HNX'\n    ELSE 'Không xác định'\n  END AS metric,\n  COUNT(DISTINCT sd.symbol) AS value\nFROM security_definition sd\nJOIN instrument_master im\n  ON sd.symbol = im.symbol AND sd.market_id = im.market_id\nWHERE sd.trading_date = CURRENT_DATE\n  AND sd.board_id = (SELECT value FROM pipeline_config WHERE key = 'symbol_filter_board_id')\n  AND (\n    COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_status'), '') = ''\n    OR sd.security_status = ANY(string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_status'), ','))\n  )\n  AND (\n    COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_admin'), '') = ''\n    OR sd.admin_status = ANY(string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_admin'), ','))\n  )\n  AND (\n    COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_sanction'), '') = ''\n    OR sd.trading_sanction_status = ANY(string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_sanction'), ','))\n  )\n  AND im.is_active = true\n  AND (\n    COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_market'), '') = ''\n    OR sd.market_id = ANY(string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_market'), ','))\n  )\n  AND (\n    (\n      COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_indexes'), '') = ''\n      AND COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_groups'), '') = ''\n    )\n    OR (\n      COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_indexes'), '') <> ''\n      AND string_to_array(im.index_name, ',') && string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_indexes'), ',')\n    )\n    OR (\n      COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_groups'), '') <> ''\n      AND im.security_group_id = ANY(string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_groups'), ','))\n    )\n  )\nGROUP BY sd.market_id\nORDER BY metric",
                    "format": "table",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "blue"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "blue",
                                "value": null
                            }
                        ]
                    },
                    "unit": "short",
                    "mappings": []
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "/^value$/",
                    "values": true
                },
                "orientation": "horizontal",
                "textMode": "value_and_name",
                "colorMode": "background",
                "text": {
                    "titleSize": 14,
                    "valueSize": 28
                },
                "graphMode": "none"
            },
            "gridPos": {
                "h": 7,
                "w": 7,
                "x": 0,
                "y": 35
            }
        },
        {
            "id": 10,
            "type": "table",
            "title": "📋 Chi tiết mã đang Subscribe (Dynamic Filter)",
            "description": "Danh sách chi tiết các mã chứng khoán đang được subscribe theo cấu hình bộ lọc động trong Database.",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT\n  sd.symbol AS \"Mã\",\n  CASE sd.market_id\n    WHEN 'STO' THEN 'Cổ phiếu sàn HOSE'\n    WHEN 'STX' THEN 'Cổ phiếu sàn HNX'\n    WHEN 'UPX' THEN 'Cổ phiếu sàn Upcom'\n    WHEN 'DVX' THEN 'Phái sinh sàn HNX'\n    WHEN 'HCX' THEN 'Trái phiếu doanh nghiệp sàn HNX'\n    ELSE 'Không xác định'\n  END AS \"Sàn\",\n  im.short_name AS \"Tên mã\"\nFROM security_definition sd\nJOIN instrument_master im\n  ON sd.symbol = im.symbol AND sd.market_id = im.market_id\nWHERE sd.trading_date = CURRENT_DATE\n  AND sd.board_id = (SELECT value FROM pipeline_config WHERE key = 'symbol_filter_board_id')\n  AND (\n    COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_status'), '') = ''\n    OR sd.security_status = ANY(string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_status'), ','))\n  )\n  AND (\n    COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_admin'), '') = ''\n    OR sd.admin_status = ANY(string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_admin'), ','))\n  )\n  AND (\n    COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_sanction'), '') = ''\n    OR sd.trading_sanction_status = ANY(string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_sanction'), ','))\n  )\n  AND im.is_active = true\n  AND (\n    COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_market'), '') = ''\n    OR sd.market_id = ANY(string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_market'), ','))\n  )\n  AND (\n    (\n      COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_indexes'), '') = ''\n      AND COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_groups'), '') = ''\n    )\n    OR (\n      COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_indexes'), '') <> ''\n      AND string_to_array(im.index_name, ',') && string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_indexes'), ',')\n    )\n    OR (\n      COALESCE((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_groups'), '') <> ''\n      AND im.security_group_id = ANY(string_to_array((SELECT value FROM pipeline_config WHERE key = 'symbol_filter_groups'), ','))\n    )\n  )\nORDER BY \"Sàn\", sd.symbol\nLIMIT 100",
                    "format": "table",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "align": "left",
                        "displayMode": "auto"
                    }
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Mã"
                        },
                        "properties": [
                            {
                                "id": "custom.width",
                                "value": 100
                            }
                        ]
                    },
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Sàn"
                        },
                        "properties": [
                            {
                                "id": "custom.width",
                                "value": 240
                            }
                        ]
                    }
                ]
            },
            "options": {
                "footer": {
                    "show": false
                },
                "showHeader": true,
                "cellHeight": "sm"
            },
            "gridPos": {
                "h": 7,
                "w": 8,
                "x": 7,
                "y": 35
            }
        },
        {
            "id": 11,
            "type": "table",
            "title": "📋 Chi tiết mã sắp đáo hạn (14 ngày tới)",
            "description": "Danh sách các mã phái sinh / chứng quyền đang active và sẽ đáo hạn trong 14 ngày tới, sắp xếp theo ngày đáo hạn gần nhất.",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT\n  sd.symbol                        AS \"Mã\",\n  CASE sd.security_group_id\n    WHEN 'ST' THEN 'Cổ phiếu'\n    WHEN 'EW' THEN 'Chứng quyền'\n    WHEN 'FU' THEN 'Hợp đồng tương lai'\n    WHEN 'EF' THEN 'Quỹ ETF'\n    WHEN 'BS' THEN 'Trái phiếu doanh nghiệp'\n    WHEN 'SR' THEN 'Quyền mua'\n    ELSE 'Không xác định'\n  END                              AS \"Định danh\",\n  sd.final_trade_date              AS \"Ngày đáo hạn\",\n  (sd.final_trade_date - CURRENT_DATE) AS \"Còn lại (ngày)\"\nFROM security_definition sd\nJOIN instrument_master im\n  ON sd.symbol = im.symbol AND sd.market_id = im.market_id\nWHERE sd.trading_date = CURRENT_DATE\n  AND sd.final_trade_date IS NOT NULL\n  AND sd.final_trade_date > CURRENT_DATE\n  AND sd.final_trade_date <= CURRENT_DATE + INTERVAL '14 days'\n  AND im.is_active = true\nORDER BY sd.final_trade_date, sd.symbol",
                    "format": "table",
                    "refId": "A"
