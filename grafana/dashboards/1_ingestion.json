                "w": 24,
                "x": 0,
                "y": 0
            }
        },
        {
            "id": 2,
            "type": "stat",
            "title": "🟢 WebSocket Status (1=Connected, 0=Disconnected)",
            "description": "Trạng thái kết nối WebSocket của từng producer. Äá» = disconnected.",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT s.service_name AS metric, COALESCE((SELECT metric_value FROM pipeline_stats WHERE service_name = s.service_name AND metric_name = 'ws_connected' AND ts > NOW() - INTERVAL '1 minute' ORDER BY ts DESC LIMIT 1), 0) AS value FROM (VALUES ('p-trade'), ('p-quote'), ('p-index'), ('p-expected-price'), ('p-foreign-investor'), ('c-trade'), ('c-quote'), ('c-index'), ('c-expected-price'), ('c-foreign-investor')) AS s(service_name) ORDER BY metric",
                    "format": "table",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "green",
                                "value": 1
                            }
                        ]
                    },
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "0": {
                                    "text": "DISCONNECTED",
                                    "color": "red"
                                },
                                "1": {
                                    "text": "CONNECTED",
                                    "color": "green"
                                }
                            }
                        }
                    ]
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "/^value$/",
                    "values": true
                },
                "orientation": "horizontal",
                "textMode": "value_and_name",
                "colorMode": "background",
                "text": {
