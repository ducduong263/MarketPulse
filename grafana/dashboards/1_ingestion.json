        {
            "id": 4,
            "type": "timeseries",
            "title": "📨 Messages/sec per Service",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT time_bucket('1 minute', ts) AS time, service_name AS metric, AVG(metric_value) AS value FROM pipeline_stats WHERE metric_name = 'msg_per_sec' AND $__timeFilter(ts) GROUP BY 1, 2 ORDER BY 1",
                    "format": "time_series",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
