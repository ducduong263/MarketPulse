    "panels": [
        {
            "id": 2,
            "type": "stat",
            "title": "🟢 Trạng thái WebSocket (1=Connected, 0=Disconnected)",
            "description": "Trạng thái kết nối WebSocket của từng producer. Đỏ = Disconnected.",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT s.service_name AS metric, COALESCE((SELECT metric_value FROM pipeline_stats WHERE service_name = s.service_name AND metric_name = 'ws_connected' AND ts > NOW() - INTERVAL '1 minute' ORDER BY ts DESC LIMIT 1), 0) AS value FROM (VALUES ('p-trade'), ('p-quote'), ('p-index'), ('p-expected-price'), ('p-foreign-investor'), ('c-trade'), ('c-quote'), ('c-index'), ('c-expected-price'), ('c-foreign-investor')) AS s(service_name) ORDER BY metric",
                    "format": "table",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "green",
                                "value": 1
                            }
                        ]
                    },
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "0": {
                                    "text": "DISCONNECTED",
                                    "color": "red"
                                },
                                "1": {
                                    "text": "CONNECTED",
                                    "color": "green"
                                }
                            }
                        }
                    ]
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "/^value$/",
                    "values": true
                },
                "orientation": "horizontal",
                "textMode": "value_and_name",
                "colorMode": "background",
                "text": {
                    "titleSize": 13,
                    "valueSize": 13
                }
            },
            "gridPos": {
                "h": 7,
                "w": 12,
                "x": 0,
                "y": 3
            }
        },
        {
            "id": 3,
            "type": "stat",
            "title": "🔄 Số lần Reconnect (kể từ khi start)",
            "description": "Số lần WebSocket reconnect. Giá trị cao = Kết nối không ổn định.",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT s.service_name AS metric, COALESCE((SELECT metric_value FROM pipeline_stats WHERE service_name = s.service_name AND metric_name = 'reconnect_count' AND ts > NOW() - INTERVAL '1 minute' ORDER BY ts DESC LIMIT 1), 0) AS value FROM (VALUES ('p-trade'), ('p-quote'), ('p-index'), ('p-expected-price'), ('p-foreign-investor'), ('c-trade'), ('c-quote'), ('c-index'), ('c-expected-price'), ('c-foreign-investor')) AS s(service_name) ORDER BY metric",
                    "format": "table",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "thresholds"
                    },
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "green",
                                "value": null
                            },
                            {
                                "color": "yellow",
                                "value": 3
                            },
                            {
                                "color": "red",
                                "value": 10
                            }
                        ]
                    },
                    "unit": "short"
                },
                "overrides": []
            },
            "options": {
                "reduceOptions": {
                    "calcs": [
                        "lastNotNull"
                    ],
                    "fields": "/^value$/",
                    "values": true
                },
                "orientation": "horizontal",
                "textMode": "value_and_name",
                "colorMode": "background",
                "text": {
                    "titleSize": 13,
                    "valueSize": 13
                }
            },
            "gridPos": {
                "h": 7,
                "w": 12,
                "x": 12,
                "y": 3
            }
        },
        {
            "id": 4,
            "type": "timeseries",
            "title": "📨 Message/sec theo Service",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT time_bucket('1 minute', ts) AS time, service_name AS metric, AVG(metric_value) AS value FROM pipeline_stats WHERE metric_name = 'msg_per_sec' AND $__timeFilter(ts) GROUP BY 1, 2 ORDER BY 1",
                    "format": "time_series",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 10
                    },
                    "unit": "mps"
                }
            },
            "options": {
                "tooltip": {
                    "mode": "multi"
                },
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom",
                    "showLegend": true
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 10
            },
            "description": "Số lượng message được xử lý mỗi giây bởi từng service."
        },
        {
            "id": 5,
            "type": "timeseries",
            "title": "❌ Số lượng lỗi Serialize Avro",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT time_bucket('5 minutes', ts) AS time, service_name AS metric, SUM(metric_value) AS value FROM pipeline_stats WHERE metric_name = 'avro_error_count' AND $__timeFilter(ts) GROUP BY 1, 2 ORDER BY 1",
                    "format": "time_series",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "fixed",
                        "fixedColor": "red"
                    },
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 20
                    },
                    "unit": "short"
                }
            },
            "options": {
                "tooltip": {
                    "mode": "multi"
                },
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom",
                    "showLegend": true
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 12,
                "y": 10
            },
            "description": "Số lượng lỗi trong quá trình serialize dữ liệu Avro."
