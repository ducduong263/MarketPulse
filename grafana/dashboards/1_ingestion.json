        {
            "id": 7,
            "type": "state-timeline",
            "title": "🔌 Connection Status per Service (Online / Offline)",
            "description": "Dải xanh = Online, Äá» = Offline. Hover vào vùng Ä‘á» để xem thá»i gian bị mất kết nối. Mỗi láº§n restart container hoặc mất máº¡ng Ä‘á»u Ä‘Æ°á»£c ghi nhận.",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT\n  $__timeFrom() AS time,\n  s.service_name AS metric,\n  COALESCE(\n    (\n      SELECT metric_value\n      FROM pipeline_stats\n      WHERE service_name = s.service_name\n        AND metric_name = 'connection_status'\n        AND ts <= $__timeFrom()\n      ORDER BY ts DESC\n      LIMIT 1\n    ), 0.0\n  ) AS value\nFROM (\n  VALUES\n    ('p-trade'), ('p-quote'), ('p-index'), ('p-expected-price'), ('p-foreign-investor'),\n    ('c-trade'), ('c-quote'), ('c-index'), ('c-expected-price'), ('c-foreign-investor')\n) AS s(service_name)\n\nUNION ALL\n\nSELECT\n  ts AS time,\n  service_name AS metric,\n  metric_value AS value\nFROM pipeline_stats\nWHERE metric_name = 'connection_status'\n  AND $__timeFilter(ts)\n\nUNION ALL\n\nSELECT\n  $__timeTo() AS time,\n  s.service_name AS metric,\n  COALESCE(\n    (\n      SELECT metric_value\n      FROM pipeline_stats\n      WHERE service_name = s.service_name\n        AND metric_name = 'connection_status'\n        AND ts <= $__timeTo()\n      ORDER BY ts DESC\n      LIMIT 1\n    ), 0.0\n  ) AS value\nFROM (\n  VALUES\n    ('p-trade'), ('p-quote'), ('p-index'), ('p-expected-price'), ('p-foreign-investor'),\n    ('c-trade'), ('c-quote'), ('c-index'), ('c-expected-price'), ('c-foreign-investor')\n) AS s(service_name)\n\nORDER BY time",
                    "format": "time_series",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "custom": {
                        "lineWidth": 1,
                        "fillOpacity": 70,
                        "connectNullValues": "always",
                        "spanNulls": true
                    },
                    "mappings": [
                        {
                            "type": "value",
                            "options": {
                                "0": {
                                    "text": "Offline",
                                    "color": "red",
                                    "index": 0
                                }
                            }
                        },
                        {
                            "type": "value",
                            "options": {
                                "1": {
                                    "text": "Online",
                                    "color": "green",
                                    "index": 1
                                }
                            }
                        }
                    ],
                    "thresholds": {
                        "mode": "absolute",
                        "steps": [
                            {
                                "color": "red",
                                "value": null
                            },
                            {
                                "color": "green",
                                "value": 1
                            }
                        ]
                    },
                    "color": {
                        "mode": "thresholds"
                    }
                }
            },
            "options": {
                "mergeValues": true,
                "showValue": "never",
                "alignValue": "center",
                "rowHeight": 0.85,
                "legend": {
                    "displayMode": "list",
                    "placement": "bottom",
                    "showLegend": true
                },
                "tooltip": {
                    "mode": "single"
                }
            },
            "gridPos": {
                "h": 8,
                "w": 24,
                "x": 0,
                "y": 26
            }
        },
        {
            "id": 8,
            "type": "row",
            "title": "📋 Instrument Master — Danh mục mã đang Subscribe",
            "collapsed": false,
            "gridPos": {
