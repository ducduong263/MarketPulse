        {
            "id": 6,
            "type": "table",
            "title": "🗜 TimescaleDB Chunk Compression Stats",
            "description": "Tỷ lệ nén của từng hypertable. Compression ratio cao = tiết kiệm disk tốt.",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT hypertable_name AS \"Bảng\", COUNT(*) AS \"Tổng chunk\", COUNT(*) FILTER (WHERE is_compressed) AS \"Đã nén\", ROUND(100.0 * COUNT(*) FILTER (WHERE is_compressed) / NULLIF(COUNT(*), 0), 1) AS \"Tỷ lệ nén (%)\" FROM timescaledb_information.chunks GROUP BY 1 ORDER BY \"Tỷ lệ nén (%)\" DESC",
                    "format": "table",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
