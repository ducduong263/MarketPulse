                                        {
                                            "color": "yellow",
                                            "value": 10
                                        },
                                        {
                                            "color": "red",
                                            "value": 60
                                        }
                                    ]
                                }
                            },
                            {
                                "id": "custom.width",
                                "value": 130
                            }
                        ]
                    },
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Insert Cuối"
                        },
                        "properties": [
                            {
                                "id": "unit",
                                "value": "dateTimeAsIso"
                            }
                        ]
                    }
                ]
            },
            "options": {
                "sortBy": [
                    {
                        "displayName": "Độ trễ",
                        "desc": true
                    }
                ],
                "footer": {
                    "show": false
                },
