        {
            "id": 3,
            "type": "timeseries",
            "title": "🚀 Latency market_trade (ms)",
            "description": "exchange_ts → dnse_ts → producer_ts → ingested_ts. Chi tiết từng chặng của luồng khớp lệnh.",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT time_bucket('1 minute', exchange_ts) AS time, ROUND(AVG(EXTRACT(EPOCH FROM (dnse_ts - exchange_ts)) * 1000)::numeric, 2) AS \"Sàn→DNSE\", ROUND(AVG(EXTRACT(EPOCH FROM (producer_ts - dnse_ts)) * 1000)::numeric, 2) AS \"DNSE→SDK\", ROUND(AVG(EXTRACT(EPOCH FROM (ingested_ts - producer_ts)) * 1000)::numeric, 2) AS \"SDK→DB\", ROUND(AVG(EXTRACT(EPOCH FROM (ingested_ts - exchange_ts)) * 1000)::numeric, 2) AS \"E2E\", ROUND((PERCENTILE_CONT(0.99) WITHIN GROUP (ORDER BY EXTRACT(EPOCH FROM (ingested_ts - exchange_ts)) * 1000))::numeric, 2) AS \"E2E P99\" FROM market_trade WHERE is_backfill = false AND $__timeFilter(exchange_ts) AND dnse_ts IS NOT NULL AND producer_ts IS NOT NULL AND ingested_ts IS NOT NULL AND market_id IN ($market_id) GROUP BY 1 ORDER BY 1",
                    "format": "time_series",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {
                    "color": {
                        "mode": "palette-classic"
                    },
                    "custom": {
                        "lineWidth": 2,
                        "fillOpacity": 5
                    },
                    "unit": "ms",
                    "min": 0
                },
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "E2E P99"
                        },
                        "properties": [
                            {
                                "id": "custom.lineStyle",
                                "value": {
                                    "fill": "dash",
                                    "dash": [
                                        10,
                                        10
                                    ]
                                }
                            },
                            {
                                "id": "custom.lineWidth",
                                "value": 3
                            }
                        ]
                    }
                ]
            },
            "options": {
                "tooltip": {
                    "mode": "multi"
                },
                "legend": {
                    "displayMode": "table",
                    "placement": "bottom",
                    "showLegend": true,
                    "calcs": [
                        "mean",
                        "max"
                    ]
                }
            },
            "gridPos": {
                "h": 8,
                "w": 12,
                "x": 0,
                "y": 15
            }
        },
