        {
            "id": 1,
            "type": "table",
            "title": "⏱ Data Freshness",
            "description": "Màu xanh < 10s, Vàng 10-60s, Đỏ > 60s. Nếu đỏ trong giờ giao dịch → producer/consumer bị treo.",
            "datasource": {
                "type": "postgres",
                "uid": "timescaledb"
            },
            "targets": [
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT 'market_trade' AS \"Bảng\", MAX(exchange_ts) AS \"Insert Cuối\", ROUND(EXTRACT(EPOCH FROM (NOW() - MAX(exchange_ts)))::numeric, 1) AS \"Độ trễ\" FROM market_trade WHERE is_backfill = false AND market_id IN ($market_id) UNION ALL SELECT 'order_book_l2', MAX(exchange_ts), ROUND(EXTRACT(EPOCH FROM (NOW() - MAX(exchange_ts)))::numeric, 1) FROM order_book_l2 WHERE is_backfill = false AND market_id IN ($market_id) UNION ALL SELECT 'market_index', MAX(exchange_ts), ROUND(EXTRACT(EPOCH FROM (NOW() - MAX(exchange_ts)))::numeric, 1) FROM market_index WHERE market_id IN ($market_id) UNION ALL SELECT 'expected_price', MAX(producer_ts), ROUND(EXTRACT(EPOCH FROM (NOW() - MAX(producer_ts)))::numeric, 1) FROM expected_price WHERE market_id IN ($market_id) UNION ALL SELECT 'foreign_investor', MAX(producer_ts), ROUND(EXTRACT(EPOCH FROM (NOW() - MAX(producer_ts)))::numeric, 1) FROM foreign_investor WHERE market_id IN ($market_id) ORDER BY \"Độ trễ\" DESC",
                    "format": "table",
                    "refId": "A"
                }
            ],
            "fieldConfig": {
                "defaults": {},
                "overrides": [
                    {
                        "matcher": {
                            "id": "byName",
                            "options": "Độ trễ"
                        },
                        "properties": [
                            {
                                "id": "unit",
                                "value": "s"
                            },
                            {
                                "id": "custom.displayMode",
                                "value": "color-background"
                            },
                            {
