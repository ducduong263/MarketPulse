            "gridPos": {
                "h": 7,
                "w": 24,
                "x": 0,
                "y": 0
            }
        },
        {
            "id": 2,
            "type": "timeseries",
            "title": "📥 Ingestion Rate — Rows/phút mỗi bảng",
            "description": "Số dòng được insert vào DB mỗi phút. Đường phẳng 0 trong giờ giao dịch = pipeline bị đứt.",
            "datasource": {
