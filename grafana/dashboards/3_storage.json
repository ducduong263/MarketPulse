                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT time_bucket('1 minute', exchange_ts) AS time, 'market_trade' AS metric, COUNT(*) AS value FROM market_trade WHERE is_backfill = false AND $__timeFilter(exchange_ts) AND market_id IN ($market_id) GROUP BY 1 ORDER BY 1",
                    "format": "time_series",
                    "refId": "A"
                },
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT time_bucket('1 minute', exchange_ts) AS time, 'order_book_l2' AS metric, COUNT(*) AS value FROM order_book_l2 WHERE is_backfill = false AND $__timeFilter(exchange_ts) AND market_id IN ($market_id) GROUP BY 1 ORDER BY 1",
                    "format": "time_series",
                    "refId": "B"
                },
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT time_bucket('1 minute', exchange_ts) AS time, 'market_index' AS metric, COUNT(*) AS value FROM market_index WHERE $__timeFilter(exchange_ts) AND market_id IN ($market_id) GROUP BY 1 ORDER BY 1",
                    "format": "time_series",
                    "refId": "C"
                },
                {
                    "datasource": {
                        "type": "postgres",
                        "uid": "timescaledb"
                    },
                    "rawSql": "SELECT time_bucket('1 minute', producer_ts) AS time, 'expected_price' AS metric, COUNT(*) AS value FROM expected_price WHERE $__timeFilter(producer_ts) AND market_id IN ($market_id) GROUP BY 1 ORDER BY 1",
