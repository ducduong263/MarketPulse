    "marketpulse"
  ],
  "templating": {
    "list": []
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "Asia/Ho_Chi_Minh",
  "title": "Layer 4 — Airflow Orchestration",
  "uid": "mp-airflow",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "📋 DAG Run Status — 24 giờ qua",
      "description": "Trạng thái các lần chạy DAG. Màu đỏ = failed. Chú ý dag_secdef_sync phải success mỗi sáng.",
      "datasource": {
        "type": "postgres",
        "uid": "airflow-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "airflow-pg"
          },
          "rawSql": "SELECT dag_id AS \"DAG\", state AS \"Trạng thái\", COUNT(*) AS \"Số lần\", MAX(end_date) AS \"Lần cuối\", ROUND(AVG(EXTRACT(EPOCH FROM (end_date - start_date)))::numeric, 1) AS \"Thời gian TB (s)\" FROM dag_run WHERE start_date > NOW() - INTERVAL '24 hours' AND state != 'running' GROUP BY dag_id, state ORDER BY dag_id, state",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Trạng thái"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "success": {
                        "text": "✅ success",
                        "color": "green"
                      },
                      "failed": {
                        "text": "❌ failed",
                        "color": "red"
                      },
                      "skipped": {
                        "text": "⏭ skipped",
                        "color": "blue"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Lần cuối"
            },
            "properties": [
              {
                "id": "unit",
                "value": "dateTimeAsIso"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Thời gian TB (s)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 300
                    },
                    {
                      "color": "red",
                      "value": 3600
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Lần cuối",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 0
      }
    },
    {
      "id": 2,
      "type": "table",
      "title": "⏱ Task Duration — Chi tiết từng task (7 ngày qua)",
      "description": "Theo dõi task dag_compact_bronze. Nếu > 60 phút cần tối ưu tài nguyên.",
      "datasource": {
        "type": "postgres",
        "uid": "airflow-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "airflow-pg"
          },
          "rawSql": "SELECT dag_id AS \"DAG\", task_id AS \"Task\", state AS \"Trạng thái\", COUNT(*) AS \"Số lần\", ROUND(AVG(EXTRACT(EPOCH FROM (end_date - start_date)))::numeric / 60, 2) AS \"TB (phút)\", ROUND(MAX(EXTRACT(EPOCH FROM (end_date - start_date)))::numeric / 60, 2) AS \"Max (phút)\" FROM task_instance WHERE start_date > NOW() - INTERVAL '7 days' AND state IN ('success', 'failed') GROUP BY dag_id, task_id, state ORDER BY dag_id, task_id",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Max (phút)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "m"
              },
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 30
                    },
                    {
                      "color": "red",
                      "value": 60
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Trạng thái"
            },
            "properties": [
              {
                "id": "custom.displayMode",
                "value": "color-background"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "success": {
                        "text": "✅",
                        "color": "green"
                      },
                      "failed": {
                        "text": "❌",
                        "color": "red"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "options": {
        "sortBy": [
          {
            "displayName": "Max (phút)",
            "desc": true
          }
        ],
        "footer": {
          "show": false
        },
        "showHeader": true
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 10
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "📈 DAG Run Timeline — Thời gian thực thi theo ngày",
      "description": "Trend thời gian chạy của các DAG quan trọng. Tăng đột biến = có vấn đề về hiệu suất.",
      "datasource": {
        "type": "postgres",
        "uid": "airflow-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "airflow-pg"
          },
          "rawSql": "SELECT date_trunc('hour', start_date) AS time, dag_id AS metric, AVG(EXTRACT(EPOCH FROM (end_date - start_date))) AS value FROM dag_run WHERE $__timeFilter(start_date) AND state = 'success' GROUP BY 1, 2 ORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5
          },
          "unit": "s"
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 20
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "🏛️ Active Symbols trong instrument_master",
      "description": "Số mã đang active. Nếu đột ngột giảm mạnh → bug deactivation hàng loạt.",
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT COUNT(*) AS value FROM instrument_master WHERE is_active = true",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100
              },
              {
                "color": "green",
                "value": 200
              }
            ]
          },
          "unit": "none",
          "mappings": []
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "/^value$/",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background"
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 28
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "📅 Security Definition (Hôm Nay)",
      "description": "Số record trong security_definition hôm nay. < 200 = dag_sync_secdef chưa chạy hoặc API trả về rỗng.",
      "datasource": {
        "type": "postgres",
