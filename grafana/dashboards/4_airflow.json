        "y": 28
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "📅 DAG dag_secdef_sync — Hôm Nay",
      "description": "Số lần dag_secdef_sync chạy thành công hôm nay. Phải = 1 vào mỗi sáng.",
      "datasource": {
        "type": "postgres",
        "uid": "airflow-pg"
      },
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "airflow-pg"
          },
          "rawSql": "SELECT COUNT(*) AS value FROM dag_run WHERE dag_id = 'dag_secdef_sync' AND state = 'success' AND (start_date AT TIME ZONE 'Asia/Ho_Chi_Minh')::date = (NOW() AT TIME ZONE 'Asia/Ho_Chi_Minh')::date",
          "format": "table",
          "refId": "A"
        }
      ],
      "fieldConfig": {
