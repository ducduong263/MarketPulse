{
  "uid": "ohlcv-candlestick-v1",
  "title": "📈 OHLCV Candlestick",
  "description": "Biểu đồ nến OHLCV real-time với đường giá hiện tại",
  "tags": ["market", "ohlcv", "candlestick"],
  "timezone": "Asia/Ho_Chi_Minh",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "refresh": "5s",
  "schemaVersion": 39,
  "time": {
    "from": "now-3h",
    "to": "now"
  },
  "timepicker": {
    "refresh_intervals": ["5s", "10s", "30s", "1m", "5m"],
    "time_options": ["5m", "15m", "1h", "3h", "6h", "12h", "24h"]
  },
  "templating": {
    "list": [
      {
        "name": "symbol",
        "type": "query",
        "label": "Mã CK",
        "datasource": {
          "type": "postgres",
          "uid": "timescaledb"
        },
        "query": "SELECT DISTINCT symbol FROM ohlcv_1min ORDER BY symbol;",
        "current": {
          "text": "VIC",
          "value": "VIC"
        },
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "interval",
        "type": "interval",
        "label": "Khung thời gian",
        "query": "1m,3m,5m,15m,30m,1h",
        "current": {
          "text": "1m",
          "value": "1m"
        },
        "auto": false
      }
    ]
  },
  "panels": [
    {
      "id": 9,
      "title": "Sổ lệnh — ${symbol}",
      "type": "table",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "WITH latest_ob AS (\n  SELECT * FROM order_book_l2\n  WHERE symbol = '${symbol}'\n  ORDER BY event_ts DESC LIMIT 1\n),\nlatest_trade AS (\n  SELECT price, quantity, session_vol\n  FROM market_trade\n  WHERE symbol = '${symbol}'\n  ORDER BY event_ts DESC LIMIT 1\n)\nSELECT\n  ob.symbol AS \"Mã\",\n  ob.bid_price3 AS \"Giá M3\", ob.bid_qty3 AS \"KL M3\",\n  ob.bid_price2 AS \"Giá M2\", ob.bid_qty2 AS \"KL M2\",\n  ob.bid_price1 AS \"Giá M1\", ob.bid_qty1 AS \"KL M1\",\n  t.price AS \"Khớp\", t.quantity AS \"KL Khớp\",\n  ob.ask_price1 AS \"Giá B1\", ob.ask_qty1 AS \"KL B1\",\n  ob.ask_price2 AS \"Giá B2\", ob.ask_qty2 AS \"KL B2\",\n  ob.ask_price3 AS \"Giá B3\", ob.ask_qty3 AS \"KL B3\",\n  t.session_vol AS \"Tổng KL\"\nFROM latest_ob ob, latest_trade t;",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center",
            "cellOptions": { "type": "color-text" },
            "inspect": false
          },
          "decimals": 2,
          "color": {
            "mode": "fixed",
            "fixedColor": "text"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Mã" },
            "properties": [
              { "id": "custom.width", "value": 60 },
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#fdcb6e" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/(Giá M|KL M)/" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#26a65b" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/(Giá B|KL B)/" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#ea3943" } }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/Khớp/" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#fdcb6e" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Tổng KL" },
            "properties": [
              { "id": "color", "value": { "mode": "fixed", "fixedColor": "#fdcb6e" } },
              { "id": "decimals", "value": 0 }
            ]
          },
          {
            "matcher": { "id": "byRegexp", "options": "/KL/" },
            "properties": [
              { "id": "decimals", "value": 0 }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": { "show": false },
        "frameIndex": 0
      }
    },
    {
      "id": 1,
      "title": "${symbol} — Biểu đồ nến ${interval}",
      "description": "",
      "type": "candlestick",
      "gridPos": { "h": 18, "w": 24, "x": 0, "y": 4 },
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT \"time\", open, high, low, close, volume FROM ohlcv_live('${symbol}', '${interval}', $__timeFrom(), $__timeTo());",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "custom": {
            "axisPlacement": "right",
            "axisLabel": "Giá (nghìn VND)",
            "hideFrom": {
              "tooltip": false,
              "viz": false,
              "legend": false
            }
          },
          "color": {
            "mode": "fixed"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "transparent",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "volume" },
            "properties": [
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "custom.axisPlacement",
                "value": "hidden"
              }
            ]
          }
        ]
      },
      "options": {
        "mode": "candles+volume",
        "candleStyle": "candles",
        "colorStrategy": "open-close",
        "colors": {
          "up": "rgba(38, 166, 91, 0.9)",
          "down": "rgba(234, 57, 67, 0.9)",
          "flat": "rgba(120, 133, 156, 0.7)"
        },
        "includeAllFields": false,
        "legend": {
          "displayMode": "hidden"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 2,
      "title": "Volume — ${symbol}",
      "type": "barchart",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 22 },
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "postgres",
            "uid": "timescaledb"
          },
          "rawSql": "SELECT\n  bucket AS \"time\",\n  buy_vol  AS \"Buy Volume\",\n  sell_vol AS \"Sell Volume\"\nFROM ohlcv_1min\nWHERE symbol = '${symbol}'\n  AND $__timeFilter(bucket)\nORDER BY bucket ASC;",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "axisPlacement": "right",
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "stacking": { "mode": "normal" }
          },
          "color": {
            "mode": "fixed"
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Buy Volume" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "rgba(38, 166, 91, 0.8)", "mode": "fixed" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Sell Volume" },
            "properties": [
              { "id": "color", "value": { "fixedColor": "rgba(234, 57, 67, 0.8)", "mode": "fixed" } }
            ]
          }
        ]
      },
      "options": {
        "orientation": "horizontal",
        "barWidth": 0.8,
        "groupWidth": 0.7,
        "xTickLabelRotation": 0,
        "showValue": "never",
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      }
    },
    {
      "id": 3,
      "title": "",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 28 },
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT price AS \"Giá hiện tại\"\nFROM market_trade\nWHERE symbol = '${symbol}'\nORDER BY event_ts DESC\nLIMIT 1;",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#26a65b", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center",
        "orientation": "auto"
      }
    },
    {
      "id": 4,
      "title": "",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 28 },
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  ROUND(CAST(sum(volume) AS numeric), 0) AS \"Tổng KL\"\nFROM ohlcv_1min\nWHERE symbol = '${symbol}'\n  AND bucket >= date_trunc('day', now() AT TIME ZONE 'Asia/Ho_Chi_Minh') AT TIME ZONE 'Asia/Ho_Chi_Minh';",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "locale",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#6C5CE7", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 5,
      "title": "",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 28 },
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  high AS \"Cao nhất\"\nFROM ohlcv_1min\nWHERE symbol = '${symbol}'\n  AND bucket >= date_trunc('day', now() AT TIME ZONE 'Asia/Ho_Chi_Minh') AT TIME ZONE 'Asia/Ho_Chi_Minh'\nORDER BY high DESC\nLIMIT 1;",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#26a65b", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 6,
      "title": "",
      "type": "stat",
      "gridPos": { "h": 4, "w": 5, "x": 15, "y": 28 },
      "datasource": {
        "type": "postgres",
        "uid": "timescaledb"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  low AS \"Thấp nhất\"\nFROM ohlcv_1min\nWHERE symbol = '${symbol}'\n  AND bucket >= date_trunc('day', now() AT TIME ZONE 'Asia/Ho_Chi_Minh') AT TIME ZONE 'Asia/Ho_Chi_Minh'\nORDER BY low ASC\nLIMIT 1;",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#ea3943", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    },
    {
      "id": 8,
      "title": "",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 28 },
      "datasource": {
        "type": "postgres",
        "uid": "${DS_TIMESCALEDB}"
      },
      "targets": [
        {
          "refId": "A",
          "rawSql": "SELECT\n  sum(tick_count) AS \"Tổng Tick\"\nFROM ohlcv_1min\nWHERE symbol = '${symbol}'\n  AND bucket >= date_trunc('day', now() AT TIME ZONE 'Asia/Ho_Chi_Minh') AT TIME ZONE 'Asia/Ho_Chi_Minh';",
          "format": "table",
          "editorMode": "code"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "locale",
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "#0984e3", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"]
        },
        "textMode": "value_and_name",
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "center"
      }
    }
  ],
  "__inputs": [
    {
      "name": "DS_TIMESCALEDB",
      "label": "TimescaleDB",
      "description": "",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "datasource",
      "id": "postgres",
      "name": "PostgreSQL",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "candlestick",
      "name": "Candlestick",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ]
}
